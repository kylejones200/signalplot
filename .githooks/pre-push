#!/usr/bin/env bash
# Pre-push: lint, tests, and package build (mirrors CI where practical).

set -euo pipefail

echo "Running pre-push checks..."

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PYTHON="${PYTHON:-python3}"

if [ ! -f pyproject.toml ]; then
    echo -e "${RED}Error: pyproject.toml not found. Run from the repository root.${NC}" >&2
    exit 1
fi

cleanup_smoke_artifact() {
    rm -f test_output.png
}
trap cleanup_smoke_artifact EXIT

echo -e "${YELLOW}Installing build + pytest + ruff + mypy (no pip upgrade)...${NC}"
if ! "$PYTHON" -m pip install -q build pytest ruff mypy; then
    echo -e "${RED}✗ Failed to install build/pytest/ruff/mypy${NC}" >&2
    exit 1
fi

echo -e "${YELLOW}Ruff format...${NC}"
if ! "$PYTHON" -m ruff format --check signalplot tests scripts; then
    echo -e "${RED}✗ Ruff format check failed (run: ruff format signalplot tests scripts)${NC}" >&2
    exit 1
fi
echo -e "${GREEN}✓ Ruff format OK${NC}"

echo -e "${YELLOW}Ruff lint...${NC}"
if ! "$PYTHON" -m ruff check signalplot tests scripts; then
    echo -e "${RED}✗ Ruff lint failed${NC}" >&2
    exit 1
fi
echo -e "${GREEN}✓ Ruff lint OK${NC}"

echo -e "${YELLOW}mypy...${NC}"
if ! "$PYTHON" -m mypy; then
    echo -e "${RED}✗ mypy failed${NC}" >&2
    exit 1
fi
echo -e "${GREEN}✓ mypy OK${NC}"

echo -e "${YELLOW}pytest...${NC}"
if ! "$PYTHON" -m pytest -q; then
    echo -e "${RED}✗ Tests failed${NC}" >&2
    exit 1
fi
echo -e "${GREEN}✓ Tests passed${NC}"

echo -e "${YELLOW}Building package...${NC}"
if ! "$PYTHON" -m build >/dev/null 2>&1; then
    echo -e "${RED}✗ Package build failed${NC}" >&2
    exit 1
fi
echo -e "${GREEN}✓ Package built${NC}"

echo -e "${YELLOW}Smoke: save to test_output.png...${NC}"
if ! "$PYTHON" -c "
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import signalplot as sp

sp.apply()
x = [i * 0.1 for i in range(100)]
y = [i * 0.1 for i in range(100)]
ax = plt.subplot()
ax.plot(x, y, color='black', linewidth=1.5)
ax.set_title('Test Plot')
sp.save('test_output.png')
plt.close('all')
"; then
    echo -e "${RED}✗ Smoke test failed${NC}" >&2
    exit 1
fi
echo -e "${GREEN}✓ Smoke test passed${NC}"

echo -e "${GREEN}✓ All pre-push checks passed.${NC}"
